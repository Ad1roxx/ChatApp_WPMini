rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      // Anyone can read user profiles (needed for showing displayNames)
      allow read: if isSignedIn();
      // Users can only write their own profile
      allow write: if isOwner(userId);
    }

    // Chats collection
    match /chats/{chatId} {
      // Users can read/write chats they're a participant in
      allow read, write: if isSignedIn() && 
        resource.data.users.hasAny([request.auth.uid]);
      
      // Allow access to messages subcollection for chat participants
      match /messages/{messageId} {
        allow read, write: if isSignedIn() &&
          get(/databases/$(database)/documents/chats/$(chatId)).data.users.hasAny([request.auth.uid]);
      }
    }

    // Default: deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
